---
import { getCollection } from 'astro:content';
import BlogLayout from '../layouts/BlogLayout.astro';

const BLOG_BASE = '';
const fallbackCover = `${BLOG_BASE}/images/default-cover.svg`;
const mainSiteUrl = 'https://houseagnet.web.app';
const publishedPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 6);

const formatDate = (date: Date) =>
  date.toLocaleDateString('zh-TW', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  });
---

<BlogLayout
  title="HouseAgent Blog | 房地產內容品牌"
  description="專業房仲內容品牌，聚焦成交策略、市場洞察與實戰案例。"
  canonicalPath={`${BLOG_BASE}/`}
  ogImage={fallbackCover}
>
  <section class="hero">
    <span class="chip">房仲行銷實戰基地</span>
    <h1>房仲業務的行銷武器庫 — 圖卡、文案、策略一次到位</h1>
    <p>
      每週更新實戰內容，幫你做出專業圖卡、寫出有說服力的文案、建立穩定的社群節奏。不用設計師，不用行銷顧問。
    </p>
    <div class="hero-actions">
      <a class="button button-primary" href={`${BLOG_BASE}/posts/`}>看文章 ✦ 免費取用</a>
      <a class="button button-ghost" href={mainSiteUrl} target="_blank" rel="noreferrer">試用圖卡工具 →</a>
    </div>
  </section>

  <section aria-labelledby="latest-posts-title">
    <div class="section-head">
      <h2 id="latest-posts-title">最新文章</h2>
      <p>以實務角度整理，手機或桌面都能快速瀏覽重點。</p>
    </div>
    <ul class="post-grid">
    {publishedPosts.map((post) => (
      <li class="post-card">
        <a class="card-link" href={`${BLOG_BASE}/posts/${post.slug}/`}>
          <div class="card-cover">
            <img
              src={post.data.cover ?? fallbackCover}
              alt={`${post.data.title} 封面`}
              loading="lazy"
              width="1280"
              height="720"
            />
          </div>
          <div class="card-body">
            <p class="card-meta">{formatDate(post.data.pubDate)}</p>
            <h3 class="card-title">{post.data.title}</h3>
            <p class="card-description">{post.data.description}</p>
            {post.data.tags.length > 0 && (
              <div class="tag-list" aria-label="文章標籤">
                {post.data.tags.slice(0, 3).map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            )}
          </div>
        </a>
      </li>
    ))}
    </ul>
  </section>
</BlogLayout>
