---
import { getCollection } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';

const BLOG_BASE = '/blog';
const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
---

<BlogLayout
  title="文章列表 | HouseAgent Blog"
  description="瀏覽 HouseAgent Blog 的全部公開文章。"
  canonicalPath={`${BLOG_BASE}/posts/`}
>
  <h1>文章列表</h1>
  <p><a href={`${BLOG_BASE}/`}>回到首頁</a></p>
  <ul>
    {posts.map((post) => (
      <li>
        <a href={`${BLOG_BASE}/posts/${post.slug}/`}>{post.data.title}</a>
        <p>{post.data.description}</p>
        <small>
          發布於 {post.data.pubDate.toISOString().slice(0, 10)}
          {post.data.tags.length > 0 ? ` | 標籤：${post.data.tags.join('、')}` : ''}
        </small>
      </li>
    ))}
  </ul>
</BlogLayout>
