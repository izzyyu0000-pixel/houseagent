---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';

const BLOG_BASE = '/blog';
const fallbackCover = `${BLOG_BASE}/images/default-cover.svg`;

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props as { post: CollectionEntry<'blog'> };
const { Content } = await post.render();
const formatDate = (date: Date) =>
  date.toLocaleDateString('zh-TW', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  });
---

<BlogLayout
  title={`${post.data.title} | HouseAgent Blog`}
  description={post.data.description}
  canonicalPath={`${BLOG_BASE}/posts/${post.slug}/`}
  ogImage={post.data.cover ?? fallbackCover}
>
  <article class="post-article">
    <p><a href={`${BLOG_BASE}/posts/`}>← 回到文章列表</a></p>
    <figure class="post-cover">
      <img
        src={post.data.cover ?? fallbackCover}
        alt={`${post.data.title} 封面`}
        width="1280"
        height="720"
      />
    </figure>
    <header class="post-header">
      <h1>{post.data.title}</h1>
      <p>
        發布於 {formatDate(post.data.pubDate)}
        {post.data.updatedDate ? ` | 更新於 ${formatDate(post.data.updatedDate)}` : ''}
      </p>
      {post.data.tags.length > 0 && (
        <div class="tag-list" aria-label="文章標籤">
          {post.data.tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </header>
    <div class="prose">
      <Content />
    </div>
  </article>
</BlogLayout>
